# =============================================================================
# NEXUS-AIKALABS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (shared instance, separate databases)
# ---------------------------------------------------------------------------
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=directus

# ---------------------------------------------------------------------------
# Directus
# ---------------------------------------------------------------------------
DIRECTUS_SECRET=CHANGE_ME_RANDOM_256BIT_STRING
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DIRECTUS_DB_DATABASE=directus
DIRECTUS_PUBLIC_URL=http://localhost:8055

# ---------------------------------------------------------------------------
# Agno AgentOS
# ---------------------------------------------------------------------------
AGNO_DB_URL=postgresql+psycopg://nexus:CHANGE_ME_STRONG_PASSWORD@postgres:5432/agno
AGNO_VECTOR_DB_URL=postgresql+psycopg://nexus:CHANGE_ME_STRONG_PASSWORD@postgres:5432/agno

# LLM API Keys (at least one required)
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings
VOYAGE_API_KEY=

# Directus connection (for MCP and REST tools)
DIRECTUS_URL=http://directus:8055
DIRECTUS_TOKEN=CHANGE_ME_DIRECTUS_API_TOKEN

# WhatsApp Business API (optional, enable when ready)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_URL=https://your-domain.com/whatsapp/webhook
# WHATSAPP_VERIFY_TOKEN=

# ---------------------------------------------------------------------------
# RustFS (S3-compatible object storage)
# ---------------------------------------------------------------------------
RUSTFS_ROOT_USER=nexus
RUSTFS_ROOT_PASSWORD=CHANGE_ME_RUSTFS_PASSWORD

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=n8n
N8N_DB_POSTGRESDB_USER=nexus
N8N_DB_POSTGRESDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---------------------------------------------------------------------------
# Prefect
# ---------------------------------------------------------------------------
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://nexus:CHANGE_ME_STRONG_PASSWORD@postgres:5432/prefect

# ---------------------------------------------------------------------------
# Traefik (SSL / Domain)
# ---------------------------------------------------------------------------
# DOMAIN=your-domain.com
# ACME_EMAIL=your-email@example.com

# ---------------------------------------------------------------------------
# Browserbase (optional, for Stagehand web browsing)
# ---------------------------------------------------------------------------
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
