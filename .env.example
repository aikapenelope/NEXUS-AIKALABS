# =============================================================================
# NEXUS-AIKALABS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (shared instance, separate databases)
# ---------------------------------------------------------------------------
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=directus

# ---------------------------------------------------------------------------
# Directus
# ---------------------------------------------------------------------------
DIRECTUS_SECRET=CHANGE_ME_RANDOM_256BIT_STRING
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DIRECTUS_DB_DATABASE=directus
DIRECTUS_PUBLIC_URL=http://localhost:8055

# ---------------------------------------------------------------------------
# Agno AgentOS
# ---------------------------------------------------------------------------
# Agno uses agno_user (created by init script) with schema agno_memory.
# Read-only access to Directus business data. Full CRUD on its own schema.
# Connection URLs are set in docker-compose.yml — no need to configure here.

# LLM API Keys (at least one required)
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings
VOYAGE_API_KEY=

# Directus connection (for MCP and REST tools)
DIRECTUS_URL=http://directus:8055
DIRECTUS_TOKEN=CHANGE_ME_DIRECTUS_API_TOKEN

# WhatsApp Business API (optional, enable when ready)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_URL=https://your-domain.com/whatsapp/webhook
# WHATSAPP_VERIFY_TOKEN=

# ---------------------------------------------------------------------------
# RustFS (S3-compatible object storage)
# ---------------------------------------------------------------------------
RUSTFS_ROOT_USER=nexus
RUSTFS_ROOT_PASSWORD=CHANGE_ME_RUSTFS_PASSWORD

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD
# n8n uses n8n_user (created by init script) with schema n8n.
# Connection is set in docker-compose.yml.

# ---------------------------------------------------------------------------
# Prefect
# ---------------------------------------------------------------------------
# Prefect uses prefect_user (created by init script) with schema prefect.
# Connection is set in docker-compose.yml.

# ---------------------------------------------------------------------------
# Traefik (SSL / Domain)
# ---------------------------------------------------------------------------
# DOMAIN=your-domain.com
# ACME_EMAIL=your-email@example.com

# ---------------------------------------------------------------------------
# Browserbase (optional, for Stagehand web browsing)
# ---------------------------------------------------------------------------
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
