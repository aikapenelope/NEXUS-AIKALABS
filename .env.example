# =============================================================================
# NEXUS-AIKALABS — Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env to version control.
# DB connections for Agno/n8n/Prefect are in docker-compose.yml (schema isolation).
# =============================================================================

# PostgreSQL (superuser for Directus only)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=directus

# Directus
DIRECTUS_SECRET=CHANGE_ME_RANDOM_256BIT_STRING
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_TOKEN=CHANGE_ME_DIRECTUS_API_TOKEN

# RustFS (S3 storage)
RUSTFS_ROOT_USER=nexus
RUSTFS_ROOT_PASSWORD=CHANGE_ME_RUSTFS_PASSWORD

# LLM API Keys (at least one required)
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings
VOYAGE_API_KEY=

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD

# WhatsApp Business API (optional)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_URL=https://your-domain.com/whatsapp/webhook
# WHATSAPP_VERIFY_TOKEN=

# Traefik SSL (optional, for production domain)
# DOMAIN=your-domain.com
# ACME_EMAIL=your-email@example.com
