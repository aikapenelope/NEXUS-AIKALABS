# =============================================================================
# NEXUS-AIKALABS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (single instance, schema isolation)
# ---------------------------------------------------------------------------
# Superuser for Directus. Service users (agno_user, n8n_user, prefect_user)
# are created automatically by config/postgres/init/00-init-databases.sql.
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=directus

# ---------------------------------------------------------------------------
# Directus
# ---------------------------------------------------------------------------
DIRECTUS_SECRET=CHANGE_ME_RANDOM_256BIT_STRING
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DIRECTUS_PUBLIC_URL=http://localhost:8055

# ---------------------------------------------------------------------------
# Agno AgentOS
# ---------------------------------------------------------------------------
# DB connections are set in docker-compose.yml (agno_user with schema isolation).

# LLM API Keys (at least one required)
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings
VOYAGE_API_KEY=

# Directus connection (for MCP and REST tools)
DIRECTUS_TOKEN=CHANGE_ME_DIRECTUS_API_TOKEN

# WhatsApp Business API (optional, enable when ready)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_URL=https://your-domain.com/whatsapp/webhook
# WHATSAPP_VERIFY_TOKEN=

# ---------------------------------------------------------------------------
# RustFS (S3-compatible object storage)
# ---------------------------------------------------------------------------
RUSTFS_ROOT_USER=nexus
RUSTFS_ROOT_PASSWORD=CHANGE_ME_RUSTFS_PASSWORD

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
# DB connection is set in docker-compose.yml (n8n_user with schema isolation).
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD

# ---------------------------------------------------------------------------
# Traefik (SSL / Domain)
# ---------------------------------------------------------------------------
# DOMAIN=your-domain.com
# ACME_EMAIL=your-email@example.com
